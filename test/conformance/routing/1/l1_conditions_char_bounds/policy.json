{
  "version": "1",
  "model_name": "user.Conditions-CharBounds",
  "recipe": "collection.router",
  "components": ["local", "cloud"],
  "routing": {
    "candidates": ["local", "cloud"],
    "default_model": "local",
    "rules": [
      { "id": "min_chars-rule",
        "match": { "min_chars": 10 },
        "route_to": "cloud" },
      { "id": "max_chars-rule",
        "match": { "max_chars": 6 },
        "route_to": "cloud" }
    ]
  }
}
