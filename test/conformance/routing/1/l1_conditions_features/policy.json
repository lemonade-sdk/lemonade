{
  "version": "1",
  "model_name": "user.Conditions-Features",
  "recipe": "collection.router",
  "components": ["local", "cloud"],
  "routing": {
    "candidates": ["local", "cloud"],
    "default_model": "local",
    "rules": [
      { "id": "has_tools-rule",
        "match": { "has_tools": true },
        "route_to": "cloud" },
      { "id": "has_images-rule",
        "match": { "has_images": true },
        "route_to": "cloud" }
    ]
  }
}
